{
  "name": "cc-archos-labs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file-if-exists=.env.local scripts/dev.mjs",
    "dev:fresh": "node --env-file-if-exists=.env.local scripts/dev-fresh.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "wip": "node scripts/wip.mjs",
    "new-branch": "node scripts/new-branch.mjs",
    "sync-branch": "node scripts/sync-branch.mjs",
    "migration-safety": "node scripts/_check-migration-safety.mjs",
    "extract-content": "node scripts/extract-content.mjs",
    "db:generate": "node --env-file=.env.local --no-warnings ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local scripts/db-apply.mjs",
    "db:studio": "node --env-file=.env.local --no-warnings ./node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "next": "16.2.5",
    "postgres": "^3.4.9",
    "puppeteer": "^24.43.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "husky": "^9.1.7",
    "kill-port": "^2.0.1",
    "lint-staged": "^17.0.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": "eslint --fix"
  }
}
