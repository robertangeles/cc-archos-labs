# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/screenshots
/playwright-report
/test-results
/tmp

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
# Claude Code local cache (per-session artifacts; never repo content)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — local secrets ignored, .env.example committed as documentation
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
