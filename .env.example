# Archos Labs — environment variables
# This file is committed to git as documentation of what secrets the app expects.
# Real values live in .env.local (gitignored). Copy this file to .env.local and fill in.
#
# Production values are managed in the Render dashboard.

# -----------------------------------------------------------------------------
# Phase 1.B — Contact form (Resend → external mailbox)
# -----------------------------------------------------------------------------
# Resend sends contact-form notifications to a recipient mailbox you read
# (typically Outlook/Gmail/etc., NOT a GoDaddy-hosted @archoslabs.xyz
# mailbox — those are silently dropped at the receiver). The From-domain
# is the verified mail.archoslabs.xyz subdomain.

# Resend API key. Get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Verified sender. Must be on a domain you've added + verified in Resend.
RESEND_FROM_EMAIL=Archos Labs <hello@mail.archoslabs.xyz>

# Where contact-form submissions land. Use a recipient mailbox that handles
# Resend mail well (Outlook, Gmail, Microsoft 365, Google Workspace) —
# avoid GoDaddy-cPanel-hosted addresses as receivers. See
# wiki/decisions/2026-05-08-godaddy-smtp-for-contact-form.md for why.
CONTACT_RECIPIENT_EMAIL=trebor.selegna@outlook.com

# -----------------------------------------------------------------------------
# Local dev server port
# -----------------------------------------------------------------------------
# Per-project port so two repos can run side-by-side without colliding.
# Default 3007. Bump if another project on your machine already owns it.
# Production: Render injects PORT at runtime; this var is local-dev only.
PORT=3007

# -----------------------------------------------------------------------------
# Phase 1.C — Site URL (used for OG tags, sitemap, canonical URLs, email links)
# -----------------------------------------------------------------------------

# Public site URL. Localhost in dev, archoslabs.xyz in prod.
# NEXT_PUBLIC_ prefix means it's exposed to the client. That's fine for the URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3007

# -----------------------------------------------------------------------------
# Phase 2.W1 — Render Postgres (Drizzle)
# -----------------------------------------------------------------------------

# Render Postgres connection string. Get from your Render Postgres service
# in the Render dashboard > Info tab > "External Database URL" (for local dev)
# or "Internal Database URL" (for the deployed web service in the same region).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Phase 2.W3 — OpenRouter (Claude) for the AI Readiness Assessment
# -----------------------------------------------------------------------------

# OpenRouter API key. Get from https://openrouter.ai/keys
# OpenRouter proxies to Anthropic with one billing surface; Archos Labs
# pays OpenRouter, OpenRouter pays Anthropic. Model id is set via
# CLAUDE_MODEL_ID below (or defaults in lib/claude.ts).
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Optional override for the OpenRouter model id. Default in
# lib/claude.ts is "anthropic/claude-sonnet-4-6". Use this to A/B
# different model revisions or fall back to an older Sonnet.
# CLAUDE_MODEL_ID=anthropic/claude-sonnet-4-6

# -----------------------------------------------------------------------------
# Phase 1.C admin / Phase 2.W4 auth — JWT session secret + admin password
# -----------------------------------------------------------------------------

# 32+ random bytes. Generate with: openssl rand -base64 32
# Or in PowerShell:
#   $b = New-Object byte[] 32
#   [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b)
#   [Convert]::ToBase64String($b)
AUTH_SECRET=replace_with_32_byte_base64_secret

# Admin login password (single admin = the operator). Use a strong password
# in production; the dev value in .env.local is fine for local work only.
ADMIN_PASSWORD=replace_with_strong_password

# -----------------------------------------------------------------------------
# Phase 2.W4/W5 — CRM webhook (where lead records are written on registration)
# -----------------------------------------------------------------------------

# Notion or Airtable webhook URL — Rob to confirm destination before W4.
# Leave empty if not yet configured; lead capture will log to server-side console
# instead of failing.
CRM_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Phase 1.E — Book a Call (Google Calendar OAuth + AES-GCM token at rest)
# -----------------------------------------------------------------------------

# 32-byte AES-256-GCM key, base64-encoded. Encrypts Rob's Google refresh
# token at rest in consultant.google_refresh_token_encrypted. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Production: use a fresh value distinct from dev.
BOOKING_ENCRYPTION_KEY=replace_with_32_byte_base64_secret

# Shared secret between the cron worker (Render Cron) and the
# /api/cron/process-scheduled endpoint that fires booking reminders,
# pre-call briefs, post-call followups, and no-show recovery emails.
# Send as `Authorization: Bearer <CRON_SECRET>` from the cron job.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Min 16 chars required; the endpoint returns 503 if shorter.
CRON_SECRET=replace_with_32_byte_url_safe_secret

# Google Cloud OAuth 2.0 client (Web application type) used by the
# /admin/google grant flow. Create at:
#   https://console.cloud.google.com/apis/credentials
# Scope required: https://www.googleapis.com/auth/calendar.events
#
# CLIENT_ID + CLIENT_SECRET now live in DB-backed Settings, NOT env.
# Go to /admin/integrations → "Google Calendar OAuth" section and paste
# them there. Same encryption-at-rest + audit-log treatment as the
# other secrets in that table. Only the redirect URI stays in env
# because it's environment-specific (localhost vs prod URL).

# Where Google sends the user after consent. Dev:
#   http://localhost:3007/api/admin/google-oauth/cb
# Prod:
#   https://www.archoslabs.xyz/api/admin/google-oauth/cb
# Must be on the "Authorized redirect URIs" list of the OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3007/api/admin/google-oauth/cb

# -----------------------------------------------------------------------------
# Phase 2.5 — Integration settings (DB-backed secrets)
# -----------------------------------------------------------------------------
# When set to "true", the integration-config loader falls back to env vars
# if the site_setting row 'integration_secrets' is missing or unreadable.
# Used during the 7-day grace window after migrating from env-only to
# DB-backed secrets. Remove or set to "false" once the DB row is stable
# and you've verified every consumer reads from it.
INTEGRATION_FALLBACK_ENABLED=true
