# Archos Labs — environment variables
# This file is committed to git as documentation of what secrets the app expects.
# Real values live in .env.local (gitignored). Copy this file to .env.local and fill in.
#
# Production values are managed in the Render dashboard.

# -----------------------------------------------------------------------------
# Phase 1.B — Contact form (GoDaddy cPanel mail server)
# -----------------------------------------------------------------------------
# Sends via the customer-friendly mail.<domain> hostname so any client IP
# (laptop, Render data center, etc.) can connect — the per-account cPanel
# server hostname has an IP firewall that blocks third-party data centers.
# See wiki/decisions/2026-05-08-godaddy-smtp-for-contact-form.md.

SMTP_HOST=mail.archoslabs.xyz
SMTP_PORT=587
SMTP_USER=rob.angeles@archoslabs.xyz
# SMTP_PASS is the GoDaddy mailbox password. Set in .env.local and Render
# env, never committed.
SMTP_PASS=
# The cPanel server's TLS cert is on a wildcard for *.prod.sin2.secureserver.net,
# not on mail.archoslabs.xyz. Set servername so nodemailer validates the
# cert against the name it actually covers. Find your cPanel hostname in
# your GoDaddy hosting dashboard, or via:
#   openssl s_client -connect mail.archoslabs.xyz:587 -starttls smtp -servername mail.archoslabs.xyz
SMTP_TLS_SERVERNAME=sg2plzcpnl493903.prod.sin2.secureserver.net
# Optional override; defaults to SMTP_USER if unset.
# SMTP_FROM=Archos Labs <rob.angeles@archoslabs.xyz>

# Where contact-form submissions land.
CONTACT_RECIPIENT_EMAIL=rob.angeles@archoslabs.xyz

# -----------------------------------------------------------------------------
# Phase 2.X — Resend (assessment reports + magic-link auth)
# -----------------------------------------------------------------------------
# Kept for Phase 2 outbound mail to external prospects (Gmail/Outlook),
# where Resend's deliverability beats GoDaddy SMTP. Not used by the
# contact form anymore.

RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=Archos Labs <hello@mail.archoslabs.xyz>

# -----------------------------------------------------------------------------
# Phase 1.C — Site URL (used for OG tags, sitemap, canonical URLs, email links)
# -----------------------------------------------------------------------------

# Public site URL. Localhost in dev, archoslabs.xyz in prod.
# NEXT_PUBLIC_ prefix means it's exposed to the client. That's fine for the URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3007

# -----------------------------------------------------------------------------
# Phase 2.W1 — Render Postgres (Drizzle)
# -----------------------------------------------------------------------------

# Render Postgres connection string. Get from your Render Postgres service
# in the Render dashboard > Info tab > "External Database URL" (for local dev)
# or "Internal Database URL" (for the deployed web service in the same region).
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Phase 2.W3 — Anthropic (Claude) for the AI Readiness Assessment
# -----------------------------------------------------------------------------

# Anthropic API key. Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# -----------------------------------------------------------------------------
# Phase 2.W4 — Magic-link auth (signs the session JWT)
# -----------------------------------------------------------------------------

# 32+ random bytes. Generate with: openssl rand -base64 32
# Or in PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
AUTH_SECRET=replace_with_32_byte_base64_secret

# -----------------------------------------------------------------------------
# Phase 2.W4/W5 — CRM webhook (where lead records are written on registration)
# -----------------------------------------------------------------------------

# Notion or Airtable webhook URL — Rob to confirm destination before W4.
# Leave empty if not yet configured; lead capture will log to server-side console
# instead of failing.
CRM_WEBHOOK_URL=
